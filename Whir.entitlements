<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Store requires the sandbox. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <!-- Read-only access to folders the user explicitly selects (~/.claude, ~/.codex),
         persisted via security-scoped bookmarks. No other file access. -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>
    <!-- Outbound HTTPS for exactly one request: refreshing the model price table
         (pricing.json) from GitHub. Off-switchable in Settings; no usage data is
         ever sent. See PricingUpdater.swift. -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
